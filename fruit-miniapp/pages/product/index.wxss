.container {
  padding-bottom: 80px;
}

.search-bar {
  padding: 12px 16px;
  background-color: #ffffff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-input-wrapper {
  position: relative;
}

.search-input {
  width: 100%;
  height: 40px;
  background-color: #f5f5f5;
  border-radius: 20px;
  padding: 0 40px 0 16px;
  font-size: 14px;
  box-sizing: border-box;
}

.search-icon {
  position: absolute;
  right: 16px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 16px;
}

.product-list {
  padding: 12px 16px;
}

.product-item {
  margin-bottom: 12px;
}

.product-header {
  margin-bottom: 12px;
}

.product-name {
  font-size: 16px;
  font-weight: bold;
  color: #333333;
}

.product-status {
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
  background-color: #f5f5f5;
  color: #999999;
}

.product-status.active {
  background-color: #e8f9f0;
  color: #07c160;
}

.product-info {
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
  font-size: 14px;
  color: #666666;
}

.info-label {
  color: #999999;
  margin-right: 4px;
}

.empty-tip {
  text-align: center;
  padding: 60px 0;
  color: #999999;
  font-size: 14px;
}

.load-more {
  text-align: center;
  padding: 16px 0;
}

.loading-text,
.load-text {
  font-size: 14px;
  color: #999999;
}

.fab {
  position: fixed;
  right: 24px;
  bottom: 24px;
  width: 56px;
  height: 56px;
  background-color: #07c160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(7, 193, 96, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 32px;
  color: #ffffff;
  line-height: 1;
}
