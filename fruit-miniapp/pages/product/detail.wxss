.container {
  padding: 16px;
  padding-bottom: 100px;
}

.info-card {
  margin-bottom: 12px;
}

.info-header {
  display: flex;
  align-items: center;
  padding-bottom: 16px;
  border-bottom: 1px solid #f0f0f0;
  margin-bottom: 16px;
}

.product-icon {
  width: 60px;
  height: 60px;
  background: linear-gradient(135deg, #ff9a44 0%, #ff6b35 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  margin-right: 16px;
}

.info-basic {
  flex: 1;
}

.product-name {
  font-size: 20px;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8px;
}

.product-status {
  display: inline-block;
  padding: 2px 12px;
  border-radius: 12px;
  font-size: 12px;
  background-color: #f5f5f5;
  color: #999999;
}

.product-status.active {
  background-color: #e8f9f0;
  color: #07c160;
}

.info-body {
}

.info-row {
  display: flex;
  margin-bottom: 12px;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  width: 80px;
  font-size: 14px;
  color: #999999;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 14px;
  color: #333333;
}

.empty-tip {
  text-align: center;
  padding: 40px 0;
  color: #999999;
  font-size: 14px;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  display: flex;
  padding: 12px 16px;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.05);
  gap: 12px;
}

.action-btn {
  flex: 1;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 8px;
}

.action-btn.delete {
  background-color: #fff0f0;
}

.action-icon {
  font-size: 18px;
  margin-right: 4px;
}

.action-text {
  font-size: 14px;
  color: #333333;
}
