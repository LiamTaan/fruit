.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 100px;
}

.form-section {
  background-color: #ffffff;
  padding: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16px;
}

.form-item {
  margin-bottom: 20px;
}

.form-label {
  font-size: 14px;
  color: #333333;
  margin-bottom: 8px;
}

.required {
  color: #fa5151;
}

.form-input {
  width: 100%;
  height: 44px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.picker-value {
  width: 100%;
  height: 44px;
  line-height: 44px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
  color: #333333;
  box-sizing: border-box;
}

.form-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  padding: 12px 16px;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.05);
}

.submit-btn {
  width: 100%;
  height: 48px;
  background-color: #07c160;
  color: #ffffff;
  border-radius: 8px;
  font-size: 16px;
  font-weight: bold;
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.6;
}
