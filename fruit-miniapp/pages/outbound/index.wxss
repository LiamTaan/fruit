.container {
  padding-bottom: 80px;
}

.search-bar {
  padding: 12px 16px;
  background-color: #ffffff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-input-wrapper {
  position: relative;
}

.search-input {
  width: 100%;
  height: 40px;
  background-color: #f5f5f5;
  border-radius: 20px;
  padding: 0 40px 0 16px;
  font-size: 14px;
  box-sizing: border-box;
}

.search-icon {
  position: absolute;
  right: 16px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 16px;
}

.filter-bar {
  display: flex;
  background-color: #ffffff;
  padding: 0 16px 12px;
  border-bottom: 1px solid #f0f0f0;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 8px 0;
  font-size: 14px;
  color: #666666;
  border-radius: 4px;
  margin: 0 4px;
}

.filter-item.active {
  background-color: #07c160;
  color: #ffffff;
}

.order-list {
  padding: 12px 16px;
}

.order-item {
  margin-bottom: 12px;
}

.order-header {
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f0f0f0;
}

.order-no {
  font-size: 14px;
  font-weight: bold;
  color: #333333;
}

.debt-badge {
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
}

.debt-badge.cash {
  background-color: #e8f9f0;
  color: #07c160;
}

.debt-badge.debt {
  background-color: #fff0f0;
  color: #fa5151;
}

.order-body {
  margin-bottom: 12px;
}

.customer-info {
  margin-bottom: 8px;
}

.customer-name {
  font-size: 14px;
  color: #666666;
}

.product-info {
  margin-bottom: 12px;
}

.product-name {
  font-size: 16px;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4px;
}

.product-spec {
  font-size: 12px;
  color: #666666;
}

.order-stats {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12px;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-label {
  font-size: 12px;
  color: #999999;
  display: block;
  margin-bottom: 4px;
}

.stat-value {
  font-size: 14px;
  color: #333333;
  font-weight: bold;
}

.stat-value.profit {
  color: #07c160;
}

.order-total {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.total-label {
  font-size: 14px;
  color: #666666;
  margin-right: 8px;
}

.total-value {
  font-size: 20px;
  font-weight: bold;
  color: #fa5151;
}

.order-footer {
  padding-top: 12px;
  border-top: 1px solid #f0f0f0;
  font-size: 12px;
  color: #666666;
}

.footer-label {
  color: #999999;
}

.empty-tip {
  text-align: center;
  padding: 60px 0;
  color: #999999;
  font-size: 14px;
}

.load-more {
  text-align: center;
  padding: 16px 0;
}

.loading-text,
.load-text {
  font-size: 14px;
  color: #999999;
}

.fab {
  position: fixed;
  right: 24px;
  bottom: 24px;
  width: 56px;
  height: 56px;
  background-color: #07c160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(7, 193, 96, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 32px;
  color: #ffffff;
  line-height: 1;
}
