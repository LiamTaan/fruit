<view class="container">
  <view class="search-bar">
    <view class="search-input-wrapper">
      <input class="search-input" type="text" placeholder="搜索果品/客户/单号" value="{{keyword}}" bindinput="onKeywordInput" />
      <view class="search-icon">🔍</view>
    </view>
  </view>

  <view class="filter-bar">
    <view class="filter-item {{currentIsDebt === '' ? 'active' : ''}}" bindtap="onFilterChange" data-is-debt="">
      全部
    </view>
    <view class="filter-item {{currentIsDebt === '0' ? 'active' : ''}}" bindtap="onFilterChange" data-is-debt="0">
      现款
    </view>
    <view class="filter-item {{currentIsDebt === '1' ? 'active' : ''}}" bindtap="onFilterChange" data-is-debt="1">
      欠款
    </view>
  </view>

  <view class="order-list">
    <view wx:if="{{orderList.length === 0 && !loading}}" class="empty-tip">
      暂无出库单据
    </view>

    <view wx:for="{{orderList}}" wx:key="id" class="order-item card" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="order-header flex-between">
        <view class="order-no">{{item.orderNo}}</view>
        <view class="debt-badge {{item.isDebt === 1 ? 'debt' : 'cash'}}">
          {{item.paymentTypeName}}
        </view>
      </view>
      <view class="order-body">
        <view class="customer-info">
          <view class="customer-name">{{item.customerName}}</view>
        </view>
        <view class="product-info">
          <view class="product-name">{{item.productName}}</view>
          <view class="product-spec" wx:if="{{item.variety || item.grade}}">
            {{item.variety}} {{item.grade}}
          </view>
        </view>
        <view class="order-stats">
          <view class="stat-item">
            <text class="stat-label">重量</text>
            <text class="stat-value">{{item.weight}}{{item.unit}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">单价</text>
            <text class="stat-value">¥{{item.unitPrice}}/{{item.unit}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">利润</text>
            <text class="stat-value {{item.profit > 0 ? 'profit' : ''}}">¥{{item.profit}}</text>
          </view>
        </view>
        <view class="order-total">
          <text class="total-label">总金额</text>
          <text class="total-value">¥{{item.totalAmount}}</text>
        </view>
      </view>
      <view class="order-footer">
        <view class="footer-item">
          <text class="footer-label">出库时间：</text>
          <text class="footer-value">{{item.outboundTime}}</text>
        </view>
        <view class="footer-item" wx:if="{{item.operatorName}}">
          <text class="footer-label">操作人：</text>
          <text class="footer-value">{{item.operatorName}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="load-more" wx:if="{{hasMore}}">
    <view wx:if="{{loading}}" class="loading-text">加载中...</view>
    <view wx:else class="load-text" bindtap="loadMore">加载更多</view>
  </view>

  <view class="fab" bindtap="goToAdd">
    <text class="fab-icon">+</text>
  </view>
</view>
