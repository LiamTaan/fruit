.container {
  padding-bottom: 80px;
}

.search-bar {
  padding: 12px 16px;
  background-color: #ffffff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-input-wrapper {
  position: relative;
}

.search-input {
  width: 100%;
  height: 40px;
  background-color: #f5f5f5;
  border-radius: 20px;
  padding: 0 40px 0 16px;
  font-size: 14px;
  box-sizing: border-box;
}

.search-icon {
  position: absolute;
  right: 16px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 16px;
}

.filter-bar {
  display: flex;
  background-color: #ffffff;
  padding: 0 16px 12px;
  border-bottom: 1px solid #f0f0f0;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 8px 0;
  font-size: 14px;
  color: #666666;
  border-radius: 4px;
  margin: 0 4px;
}

.filter-item.active {
  background-color: #07c160;
  color: #ffffff;
}

.stock-list {
  padding: 12px 16px;
}

.stock-item {
  margin-bottom: 12px;
}

.stock-item.low-stock {
  border-left: 4px solid #fa5151;
}

.stock-header {
  margin-bottom: 8px;
}

.product-name {
  font-size: 16px;
  font-weight: bold;
  color: #333333;
}

.stock-badge {
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
  background-color: #fff0f0;
  color: #fa5151;
}

.product-spec {
  font-size: 12px;
  color: #666666;
  margin-bottom: 12px;
}

.stock-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12px;
}

.info-item {
  text-align: center;
  flex: 1;
}

.info-label {
  font-size: 12px;
  color: #999999;
  display: block;
  margin-bottom: 4px;
}

.info-value {
  font-size: 14px;
  color: #333333;
  font-weight: bold;
}

.stock-footer {
  padding-top: 12px;
  border-top: 1px solid #f0f0f0;
  font-size: 12px;
}

.warning-label {
  color: #999999;
}

.warning-value {
  color: #fa5151;
}

.empty-tip {
  text-align: center;
  padding: 60px 0;
  color: #999999;
  font-size: 14px;
}

.load-more {
  text-align: center;
  padding: 16px 0;
}

.loading-text,
.load-text {
  font-size: 14px;
  color: #999999;
}
