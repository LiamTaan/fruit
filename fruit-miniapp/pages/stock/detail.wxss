.container {
  padding: 16px;
}

.info-card {
  margin-bottom: 12px;
}

.info-header {
  display: flex;
  align-items: center;
  padding-bottom: 16px;
  border-bottom: 1px solid #f0f0f0;
  margin-bottom: 16px;
}

.product-icon {
  width: 60px;
  height: 60px;
  background: linear-gradient(135deg, #ff9a44 0%, #ff6b35 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  margin-right: 16px;
}

.info-basic {
  flex: 1;
}

.product-name {
  font-size: 20px;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8px;
}

.stock-badge {
  display: inline-block;
  padding: 2px 12px;
  border-radius: 12px;
  font-size: 12px;
  background-color: #fff0f0;
  color: #fa5151;
}

.info-body {
}

.info-row {
  display: flex;
  margin-bottom: 12px;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-row.highlight {
  padding-top: 12px;
  padding-bottom: 12px;
  background-color: #e8f9f0;
  margin-left: -16px;
  margin-right: -16px;
  padding-left: 16px;
  padding-right: 16px;
  margin-bottom: 12px;
  border-radius: 8px;
}

.info-label {
  width: 100px;
  font-size: 14px;
  color: #999999;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 14px;
  color: #333333;
  text-align: right;
}

.text-primary {
  color: #07c160;
  font-weight: bold;
  font-size: 18px;
}

.text-danger {
  color: #fa5151;
  font-weight: bold;
}

.empty-tip {
  text-align: center;
  padding: 40px 0;
  color: #999999;
  font-size: 14px;
}
