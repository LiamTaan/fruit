.container {
  padding: 0;
  margin: 0;
  font-size: 16px;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left,
.header-right {
  width: 60rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  text-align: center;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
}

.help-container {
  background-color: #fff;
  margin-top: 20rpx;
  padding-bottom: 40rpx;
}

.help-section {
  padding: 0 30rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin: 40rpx 0 20rpx 0;
}

.faq-list {
  width: 100%;
}

.faq-item {
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  background-color: #fff;
  font-size: 32rpx;
  color: #333;
}

.question-text {
  flex: 1;
  line-height: 1.5;
}

.question-arrow {
  font-size: 24rpx;
  color: #999;
  transition: transform 0.3s ease;
}

.faq-answer {
  padding: 0 0 30rpx 0;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  background-color: #fff;
}

.contact-info {
  padding: 20rpx 0;
}

.contact-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 30rpx;
}

.contact-label {
  color: #666;
  margin-right: 20rpx;
  width: 120rpx;
}

.contact-value {
  color: #333;
  font-weight: 500;
  flex: 1;
}