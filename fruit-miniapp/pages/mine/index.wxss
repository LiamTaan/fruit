.user-card {
  margin-bottom: 16px;
}

.user-info {
  padding: 16px 0;
  align-items: center;
}

.user-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 16px;
  background-color: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  color: white;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.user-detail {
  flex: 1;
}

.user-nickname {
  font-size: 18px;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4px;
}

.user-role {
  font-size: 14px;
}

.menu-list {
  margin-bottom: 16px;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 0;
  border-bottom: 1px solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  flex: 1;
}

.menu-icon {
  font-size: 20px;
  margin-right: 12px;
}

.menu-text {
  font-size: 14px;
  color: #333333;
}

.menu-arrow {
  color: #999999;
  font-size: 14px;
}

.logout-btn {
  background-color: #ffffff;
  color: #fa5151;
  border-radius: 8px;
  height: 44px;
  line-height: 44px;
  text-align: center;
  font-size: 16px;
  margin-top: 16px;
}

.login-btn {
  background-color: #07c160;
  color: #ffffff;
  border-radius: 8px;
  height: 44px;
  line-height: 44px;
  text-align: center;
  font-size: 16px;
  margin-top: 16px;
}
