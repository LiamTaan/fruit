.container {
  padding: 0;
  margin: 0;
  font-size: 16px;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left,
.header-right {
  width: 60rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  text-align: center;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
}

.form-container {
  background-color: #fff;
  padding: 40rpx 30rpx;
  margin-top: 20rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.form-input {
  height: 80rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  color: #333;
  background-color: #fafafa;
  width: 100%;
}

.form-input:focus {
  border-color: #409eff;
  background-color: #fff;
}

.form-tips {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
  text-align: right;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 45rpx;
  background-color: #409eff;
  color: #fff;
  margin-top: 20rpx;
}

.submit-btn[disabled] {
  background-color: #c6e2ff;
  color: #fff;
}

.submit-btn:not([disabled]):active {
  background-color: #66b1ff;
}