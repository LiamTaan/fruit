.container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32px;
  background: linear-gradient(135deg, #07c160 0%, #06a856 100%);
}

.login-card {
  width: 100%;
  background-color: #ffffff;
  border-radius: 16px;
  padding: 40px 32px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.login-title {
  font-size: 28px;
  font-weight: bold;
  color: #07c160;
  text-align: center;
  margin-bottom: 8px;
}

.login-subtitle {
  font-size: 14px;
  color: #999999;
  text-align: center;
  margin-bottom: 40px;
}

.form-item {
  margin-bottom: 24px;
}

.form-label {
  font-size: 14px;
  color: #333333;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 48px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 16px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #07c160;
}

.login-btn {
  width: 100%;
  height: 48px;
  background-color: #07c160;
  color: #ffffff;
  border-radius: 8px;
  line-height: 48px;
  text-align: center;
  font-size: 16px;
  font-weight: bold;
  margin-top: 16px;
}

.login-btn:active {
  opacity: 0.8;
}

.login-tip {
  margin-top: 24px;
  text-align: center;
}

.login-tip text {
  font-size: 12px;
  color: #999999;
}
