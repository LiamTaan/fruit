<view class="container" wx:if="{{customer}}">
  <view class="info-card card">
    <view class="info-header">
      <view class="customer-avatar">
        <image wx:if="{{customer.avatar}}" class="avatar-img" src="{{customer.avatar}}" mode="aspectFill"></image>
        <text wx:else class="avatar-text">{{customer.name.charAt(0)}}</text>
      </view>
      <view class="info-basic">
        <view class="customer-name">{{customer.name}}</view>
        <view class="customer-category category-{{customer.category}}">
          {{customer.categoryName}}
        </view>
      </view>
    </view>

    <view class="info-body">
      <view class="info-row" wx:if="{{customer.phone}}">
        <view class="info-label">电话</view>
        <view class="info-value" bindtap="callPhone" data-phone="{{customer.phone}}">
          {{customer.phone}}
        </view>
      </view>
      <view class="info-row" wx:if="{{customer.address}}">
        <view class="info-label">地址</view>
        <view class="info-value">{{customer.address}}</view>
      </view>
      <view class="info-row">
        <view class="info-label">创建时间</view>
        <view class="info-value">{{customer.createdAt}}</view>
      </view>
      <view class="info-row" wx:if="{{customer.remark}}">
        <view class="info-label">备注</view>
        <view class="info-value">{{customer.remark}}</view>
      </view>
    </view>
  </view>

  <view class="stats-card card">
    <view class="stats-header">交易统计</view>
    <view class="stats-body">
      <view class="stat-item">
        <view class="stat-value">¥{{customer.totalAmount}}</view>
        <view class="stat-label">总交易额</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value {{customer.debtAmount > 0 ? 'text-danger' : ''}}">¥{{customer.debtAmount}}</view>
        <view class="stat-label">欠款金额</view>
      </view>
    </view>
  </view>

  <view class="history-section card">
    <view class="section-header">
      <text class="section-title">历史交易记录</text>
    </view>
    
    <view class="transaction-list">
      <view wx:if="{{transactionList.length === 0 && !loading}}" class="empty-tip">
        暂无交易记录
      </view>
      
      <view wx:for="{{transactionList}}" wx:key="id" class="transaction-item">
        <view class="transaction-header flex-between">
          <view class="order-no">{{item.orderNo}}</view>
          <view class="order-time">{{item.createTime}}</view>
        </view>
        <view class="transaction-body">
          <view class="product-info">
            <view class="product-name">{{item.productName}}</view>
            <view class="product-spec">
              <text wx:if="{{item.variety}}">{{item.variety}}</text>
              <text wx:if="{{item.grade}}"> / {{item.grade}}</text>
            </view>
          </view>
          <view class="transaction-stats">
            <view class="stat-item">
              <text class="stat-label">重量</text>
              <text class="stat-value">{{item.weight}}{{item.unit}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">单价</text>
              <text class="stat-value">¥{{item.unitPrice}}/{{item.unit}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">总价</text>
              <text class="stat-value total-value">¥{{item.totalAmount}}</text>
            </view>
          </view>
          <view class="payment-type payment-type-{{item.paymentType}}">
            {{item.paymentTypeName}}
          </view>
        </view>
      </view>
    </view>
    
    <view class="load-more" wx:if="{{hasMore}}">
      <view wx:if="{{loading}}" class="loading-text">加载中...</view>
      <view wx:else class="load-text" bindtap="loadMore">加载更多</view>
    </view>
  </view>
</view>

<view class="action-bar" wx:if="{{customer}}">
  <view class="action-btn" bindtap="editCustomer">
    <text class="action-icon">✏️</text>
    <text class="action-text">编辑</text>
  </view>
  <view class="action-btn delete" bindtap="deleteCustomer">
    <text class="action-icon">🗑️</text>
    <text class="action-text">删除</text>
  </view>
</view>
