.container {
  padding: 16px;
  padding-bottom: 100px;
}

.info-card {
  margin-bottom: 12px;
}

.info-header {
  display: flex;
  align-items: center;
  padding-bottom: 16px;
  border-bottom: 1px solid #f0f0f0;
  margin-bottom: 16px;
}

.customer-avatar {
  width: 60px;
  height: 60px;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  font-weight: bold;
  color: #ffffff;
  margin-right: 16px;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.info-basic {
  flex: 1;
}

.customer-name {
  font-size: 20px;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8px;
}

.customer-category {
  display: inline-block;
  padding: 2px 12px;
  border-radius: 12px;
  font-size: 12px;
}

.category-1 {
  background-color: #e8f9f0;
  color: #07c160;
}

.category-2 {
  background-color: #f5f5f5;
  color: #666666;
}

.category-3 {
  background-color: #fff0f0;
  color: #fa5151;
}

.info-body {
}

.info-row {
  display: flex;
  margin-bottom: 12px;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  width: 80px;
  font-size: 14px;
  color: #999999;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 14px;
  color: #333333;
}

.stats-card {
  margin-bottom: 12px;
}

.stats-header {
  font-size: 16px;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16px;
}

.stats-body {
  display: flex;
  align-items: center;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 24px;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4px;
}

.stat-label {
  font-size: 12px;
  color: #999999;
}

.stat-divider {
  width: 1px;
  height: 40px;
  background-color: #f0f0f0;
}

.text-danger {
  color: #fa5151;
}

.empty-tip {
  text-align: center;
  padding: 40px 0;
  color: #999999;
  font-size: 14px;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  display: flex;
  padding: 12px 16px;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.05);
  gap: 12px;
}

.action-btn {
  flex: 1;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 8px;
}

.action-btn.delete {
  background-color: #fff0f0;
}

.action-icon {
  font-size: 18px;
  margin-right: 4px;
}

.action-text {
  font-size: 14px;
  color: #333333;
}

/* 历史交易记录样式 */
.history-section {
  margin-bottom: 12px;
}

.section-header {
  margin-bottom: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333333;
}

.transaction-list {
  margin-top: 16px;
}

.transaction-item {
  padding: 16px 0;
  border-bottom: 1px solid #f0f0f0;
}

.transaction-item:last-child {
  border-bottom: none;
}

.transaction-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12px;
}

.order-no {
  font-size: 14px;
  font-weight: bold;
  color: #333333;
}

.order-time {
  font-size: 12px;
  color: #999999;
}

.product-info {
  margin-bottom: 12px;
}

.product-name {
  font-size: 14px;
  color: #333333;
  margin-bottom: 4px;
}

.product-spec {
  font-size: 12px;
  color: #999999;
}

.transaction-stats {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12px;
}

.transaction-stats .stat-item {
  text-align: center;
  flex: 1;
}

.transaction-stats .stat-label {
  font-size: 12px;
  color: #999999;
  display: block;
  margin-bottom: 4px;
}

.transaction-stats .stat-value {
  font-size: 14px;
  color: #333333;
}

.transaction-stats .total-value {
  font-weight: bold;
  color: #07c160;
}

.payment-type {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
}

.payment-type-1 {
  background-color: #e8f9f0;
  color: #07c160;
}

.payment-type-2 {
  background-color: #fff0f0;
  color: #fa5151;
}

/* 加载更多样式 */
.load-more {
  text-align: center;
  padding: 16px 0;
  font-size: 14px;
  color: #999999;
}

.loading-text {
  font-size: 14px;
  color: #999999;
}

.load-text {
  font-size: 14px;
  color: #07c160;
}

/* Flex布局工具类 */
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
